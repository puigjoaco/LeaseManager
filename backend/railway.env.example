# Variables mínimas para backend-web y backend-worker en Railway

DJANGO_SECRET_KEY=__SET_ME__
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=__SET_ME__
DJANGO_CORS_ALLOWED_ORIGINS=https://leasemanager-backoffice.vercel.app
DJANGO_CSRF_TRUSTED_ORIGINS=https://leasemanager-backoffice.vercel.app
DJANGO_SECURE_SSL_REDIRECT=true
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=true
DJANGO_SECURE_HSTS_PRELOAD=false
DATABASE_URL=__SET_FROM_DATABASE_SERVICE_OR_SUPABASE__
REDIS_URL=__SET_FROM_REDIS_SERVICE__
CELERY_RESULT_BACKEND=__SET_FROM_REDIS_SERVICE__
DJANGO_CACHE_URL=
DEMO_LOGIN_USERS=demo-admin,demo-operador,demo-revisor,demo-socio
DEMO_LOGIN_PASSWORD=demo12345
FRONTEND_URL=https://leasemanager-backoffice.vercel.app
LEGACY_ROOT_PATH=/app
DATA_EXPORT_ENCRYPTION_KEY=
CELERY_LOGLEVEL=info
